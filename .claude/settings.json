{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pre-commit run --all-files",
            "if": "Bash(git commit*)",
            "statusMessage": "Running pre-commit checks..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(pip install:*)",
      "Bash(pip3 index:*)",
      "Bash(pip3 install:*)",
      "Bash(pre-commit:*)",
      "Bash(pyenv shell:*)",
      "Bash(pyenv versions:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(ruff:*)",
      "Bash(source:*)",
      "Bash(wc:*)",
      "WebFetch(domain:github.com)"
    ]
  }
}
